import os
import smtplib


SMTP_SENDER="your@gmail.com"
SMTP_APP_PASSWORD="your-16-char-gmail-app-password"
SMTP_RECEIVER="recipient@example.com"


if not sender or not password:
    print("Gmail credentials are not configured.")
    print("Set SMTP_SENDER, SMTP_APP_PASSWORD, and optionally SMTP_RECEIVER as environment variables.")
    print("Note: Gmail requires an app password, not your regular account password.")
    raise SystemExit(1)

message = """
Subject: Python Automation Test

Hello,
This email was sent automatically using Python.
"""

try:
    server = smtplib.SMTP("smtp.gmail.com", 587)
    server.starttls()
    server.login(sender, password)
    server.sendmail(sender, receiver, message)
    server.quit()
    print("Email sent successfully!")
except smtplib.SMTPAuthenticationError:
    print("Authentication failed. Verify your Gmail address and app password.")
    raise
except Exception as exc:
    print(f"Failed to send email: {exc}")
    raise